            content: '<div class="_accordionBody_wtqk4_104">
                        <img srcset="/img/decouvrir/hosting-sharing-sensitive-data.svg" alt="">
                        <div>
                          <p class="fr-m-0 fr-mb-4v">Stockez vos données sensibles ou stratégiques au sein d’une infrastructure souveraine opérée par l’État. Définissez les droits d’accès, créez des flux privés ou restreints et maîtrisez totalement la diffusion de vos données. Une solution conçue pour les collectivités, opérateurs publics et services métiers manipulant des données critiques.</p>
                          <div class="_accordionButtons_wtqk4_118">
                            <a href="/aide/fr/guides-producteur/publier-des-donnees-via-cartes-gouv/" class="fr-link" target="_blank" data-fr-js-link-actionee="true">En savoir plus</a>
                          </div>
                        </div>
                      </div>'           
          },
